# --- Lead form ---
# Optional: if both are set, /api/leads will email each submission via Resend.
# Without these, leads are still validated, logged to the server, and (in dev)
# appended to data/leads.jsonl — but no email is sent.
# RESEND_API_KEY=re_xxx
# LEADS_TO_EMAIL=[email protected]
# LEADS_FROM_EMAIL=[email protected]   # must be a verified sender on Resend

# Optional: CRM webhook. When set, every successful lead is POSTed as
# JSON to this URL. Works with HubSpot / Pipedrive / Make / Zapier /
# n8n — any endpoint that accepts JSON. Failures are logged and
# swallowed so a downstream outage never blocks lead capture.
# LEADS_WEBHOOK_URL=https://hooks.zapier.com/...
# Optional shared secret — when present, payloads are signed with
# HMAC-SHA256 and the hex digest is sent in the x-mitoderm-signature
# header (format: "sha256=<digest>") for the receiver to verify.
# LEADS_WEBHOOK_SECRET=replace-with-a-long-random-string

# Optional: nightly leads mirror. When LEADS_MIRROR_TOKEN is set,
# POST /api/admin/leads/mirror?token=… (typically from a scheduled
# cron like Vercel Cron or GitHub Actions) commits a JSON snapshot of
# the current leads to the repo (requires the GITHUB_* vars above).
# LEADS_MIRROR_TOKEN=replace-with-a-long-random-string

# --- Admin (catalog editor at /admin) ---
# Required: the single password used to sign into /admin. Sessions are
# stored in a signed HttpOnly cookie. If unset, /admin login always fails.
# ADMIN_PASSWORD=replace-with-a-long-random-string

# Optional: when the four GitHub vars below are set, admin saves are
# committed to the repo via the GitHub Contents API (Vercel auto-redeploys).
# If they’re not set, saves are written to the local file — fine for dev,
# but they would NOT persist on Vercel (read-only filesystem).
# GITHUB_TOKEN=ghp_xxx              # fine-grained PAT with Contents: Read+Write
# GITHUB_OWNER=gregorydich
# GITHUB_REPO=mitoderm
# GITHUB_BRANCH=main                # branch to commit to (default: main)

# --- WhatsApp ---
# Optional but recommended. When set, the product-page "Contact for Price"
# CTA becomes a wa.me deep-link with a pre-filled per-product message in
# the visitor's locale (en / ru / he). Israel-friendly conversion path.
# International format, digits only (e.g. 972541234567).
# NEXT_PUBLIC_WHATSAPP_NUMBER=972541234567

# --- Analytics ---
# NEXT_PUBLIC_GOOGLE_ID=G-XXXXXXXXXX
