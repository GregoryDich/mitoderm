# --- Lead form ---
# Optional: if both are set, /api/leads will email each submission via Resend.
# Without these, leads are still validated, logged to the server, and (in dev)
# appended to data/leads.jsonl — but no email is sent.
# RESEND_API_KEY=re_xxx
# LEADS_TO_EMAIL=[email protected]
# LEADS_FROM_EMAIL=[email protected]   # must be a verified sender on Resend

# --- Admin (catalog editor at /admin) ---
# Required: the single password used to sign into /admin. Sessions are
# stored in a signed HttpOnly cookie. If unset, /admin login always fails.
# ADMIN_PASSWORD=replace-with-a-long-random-string

# Optional: when the four GitHub vars below are set, admin saves are
# committed to the repo via the GitHub Contents API (Vercel auto-redeploys).
# If they’re not set, saves are written to the local file — fine for dev,
# but they would NOT persist on Vercel (read-only filesystem).
# GITHUB_TOKEN=ghp_xxx              # fine-grained PAT with Contents: Read+Write
# GITHUB_OWNER=gregorydich
# GITHUB_REPO=mitoderm
# GITHUB_BRANCH=main                # branch to commit to (default: main)

# --- Analytics ---
# NEXT_PUBLIC_GOOGLE_ID=G-XXXXXXXXXX
